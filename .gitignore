# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
# …but keep the packaging build inputs (Nuitka + Inno Setup scripts):
!build/
build/output/
build/dist/

# Nuitka leaves a crash report if the build is killed / interrupted.
nuitka-crash-report.xml

# Database files — NEVER commit company data
data/companies/*.db
data/companies/*.db-wal
data/companies/*.db-shm

# Local license server SQLite (dev only — prod lives on Fly volume)
licenses.db
licenses.db-wal
licenses.db-shm
license_server/licenses.db
license_server/licenses.db-wal
license_server/licenses.db-shm

# Eclipse
.project
.pydevproject
.settings/
.classpath

# OS
.DS_Store
Thumbs.db
desktop.ini

# Virtual env
venv/
.venv/
env/

# Secrets
.env
*.key
api_keys.txt

# Agent worktrees (Claude Code creates these for parallel subagents)
.claude/

# Per-machine runtime state lives in data/ in dev mode (DBs, credits, license)
data/

# Per-machine / per-deployment config — seeded by app on first run
config/user_prefs.json
config/pricing.json
config/ai_routing.json
config/display_config.json

# Stray drafts / one-off HTML
theme.html
docs/*.html