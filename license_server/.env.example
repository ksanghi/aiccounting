# Copy to .env and fill in. Never commit the real .env.

# SQLite path (default ./licenses.db) or full Postgres URL
DATABASE_URL=sqlite:///./licenses.db

# Token required for admin endpoints (mint, list, revoke).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-me-to-a-long-random-string

# Max machines a single license key can be activated on
MAX_MACHINES_PER_KEY=3

# App version this server is compatible with (informational)
SERVER_VERSION=1.0.0
